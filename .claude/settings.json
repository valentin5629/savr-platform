{
  "hooks": {
    "PostToolUse": [
      { "matcher": "Write|Edit", "hooks": [ { "type": "command", "command": "bash .claude/hooks/format-file.sh" } ] }
    ],
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [
        { "type": "command", "command": "bash .claude/hooks/block-destructive.sh" },
        { "type": "command", "command": "bash .claude/hooks/pre-commit-gate.sh" }
      ] }
    ]
  }
}
