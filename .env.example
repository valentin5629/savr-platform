# =============================================================================
# Savr Platform — Variables d'environnement (template)
# =============================================================================
# Copier en .env.local (jamais committé). Secrets réels = Supabase Vault +
# Vercel Environment Variables. Voir CLAUDE.md §11 pour les 2 envs (dev / prod).
#
# Après `supabase link`, récupérer URL + clés via :
#   supabase status          (local Docker)
#   supabase projects list   (remote — nécessite SUPABASE_ACCESS_TOKEN)

# -----------------------------------------------------------------------------
# Supabase — projet dev : savr-dev (eu-west-3 West EU Paris)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connexion directe PostgreSQL (migrations, seeds, smoke-test)
# Pooler (app)  : postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
# Direct (DDL)  : postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=
DIRECT_URL=

# Référence du projet (visible dans l'URL du dashboard Supabase)
SUPABASE_PROJECT_REF=
# Token d'accès CLI (générer sur https://app.supabase.com/account/tokens)
SUPABASE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Railway — Service PDF (Puppeteer headless, cf. CLAUDE.md §2)
# -----------------------------------------------------------------------------
RAILWAY_PDF_URL=
RAILWAY_PDF_SECRET=

# -----------------------------------------------------------------------------
# Resend — Emails transactionnels (19 templates actifs V1)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_DOMAIN=

# -----------------------------------------------------------------------------
# Cloudflare R2 — Stockage fichiers volumineux (PDFs, photos MTS-1)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=

# -----------------------------------------------------------------------------
# MTS-1 (Strike/Marathon) — Adapter logistique V1
# Bearer token statique (secret réel = Supabase Vault). Jamais référencé hors
# packages/adapters/. ⚠ Ce sont les 2 SEULES variables lues par le code
# (packages/adapters/src/mts1/client.ts) — les noms doivent correspondre exactement.
# -----------------------------------------------------------------------------
MTS1_BASE_URL=
MTS1_API_KEY=

# -----------------------------------------------------------------------------
# Health check ops — GET /api/health/logistique
# Token interne optionnel pour le monitoring/CI (sinon auth session admin_savr).
# -----------------------------------------------------------------------------
HEALTH_INTERNAL_TOKEN=

# -----------------------------------------------------------------------------
# Pennylane — Facturation (brouillons ZD + AG)
# -----------------------------------------------------------------------------
PENNYLANE_API_KEY=

# -----------------------------------------------------------------------------
# Observabilité (CLAUDE.md §13 — Sentry / Slack / Better Uptime)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# 3 canaux Slack par sévérité (alertes fonctionnelles restent in-app)
SLACK_WEBHOOK_CRITIQUE=
SLACK_WEBHOOK_ELEVE=
SLACK_WEBHOOK_INFO=

BETTER_UPTIME_API_KEY=
