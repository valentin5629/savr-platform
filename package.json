{
  "name": "savr-monorepo",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "build": "turbo run build",
    "prepare": "husky || true",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset --local",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > packages/shared/src/database.types.ts",
    "db:smoke": "bash scripts/smoke-test-db.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^25.9.3",
    "eslint": "^9.14.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "type": "module"
}
