{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.gosavr.io/2026.04/sortants/S3.tournee-upsert.schema.json",
  "title": "S3 — POST /webhooks/tms/tournee-upsert (tournee.upsert)",
  "description": "TMS → Plateforme. Création/modif d'une tournée (M04). collecte_ids[] réconcilie la liaison N↔N plateforme.collecte_tournees (multi-camions + mutualisation). NB : enveloppe omise dans la prose, normalisée 2026-06-03.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "event_id": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/uuid" },
    "emis_le": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/timestamp" },
    "occurred_at": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/timestamp" },
    "source": { "type": "string", "const": "tms" },
    "type": { "type": "string", "const": "tournee.upsert" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tournee_id": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/uuid" },
        "prestataire_id": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/uuid" },
        "collecte_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/uuid" }
        },
        "heure_debut_prevue": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/timestamp" },
        "heure_fin_prevue": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/timestamp" },
        "statut": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/enum_statut_tournee" },
        "chauffeur_id": { "type": ["string", "null"], "format": "uuid" },
        "vehicule_id": { "type": ["string", "null"], "format": "uuid" },
        "type_vehicule_categorie_plateforme": { "$ref": "https://contracts.gosavr.io/2026.04/common.schema.json#/$defs/enum_type_vehicule_categorie_plateforme" }
      },
      "required": ["tournee_id", "prestataire_id", "collecte_ids", "heure_debut_prevue", "heure_fin_prevue", "statut", "type_vehicule_categorie_plateforme"]
    }
  },
  "required": ["event_id", "occurred_at", "source", "type", "data"]
}
