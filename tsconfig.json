{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "baseUrl": ".",
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["packages/plateforme/src/*"]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": [
    "packages/plateforme/next.config.ts",
    "packages/plateforme/sentry.client.config.ts",
    "packages/plateforme/sentry.server.config.ts",
    "packages/**/node_modules",
    "packages/shared/src/supabase-client.typed.ts"
  ]
}
